# Configuração para a suite de testes do backend.
# Copie este arquivo para `.env.test` (que está no .gitignore) e use APENAS com o
# banco de testes (docker-compose.test.yml — Postgres na porta 5433).
#
# Subir o banco de testes:
#   docker compose -f docker-compose.test.yml up -d
#
# IMPORTANTE: DATABASE_URL aqui DEVE apontar para um banco isolado de teste.
# O setup do Vitest aborta a execução se a URL não terminar em `_test`.

DATABASE_URL="postgresql://postgres:postgres@localhost:5434/mini_erp_test"
JWT_SECRET="test_jwt_secret_local_only"
RESET_JWT_SECRET="test_reset_jwt_secret_local_only"
APP_URL="http://localhost:5173"
NODE_ENV="test"
PORT=3002
FRONTEND_URL="http://localhost:3000"
